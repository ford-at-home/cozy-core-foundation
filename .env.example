# Client-side (VITE_-prefixed) values are PUBLISHABLE — they ship in the
# browser bundle by design. Everything secret (service role key, Stripe keys,
# provider API keys) lives in Lovable Cloud backend secrets, never in env
# files here. The complete configuration inventory is docs/CONFIGURATION.md;
# backend secrets checklists are docs/RUNBOOK.md and docs/BILLING.md.

# SSR / server-side reads (process.env)
SUPABASE_URL="https://dlaojinagezrlbwyritd.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<supabase anon/publishable key>"

# Browser bundle reads (import.meta.env)
VITE_SUPABASE_URL="https://dlaojinagezrlbwyritd.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase anon/publishable key>"
