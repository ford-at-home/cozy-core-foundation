# Client-side (VITE_-prefixed) values are PUBLISHABLE — they ship in the
# browser bundle by design. Everything secret (service role key, provider API
# keys) lives in Lovable Cloud backend secrets, never in env files here.
# See docs/RUNBOOK.md for the full backend secrets checklist.

SUPABASE_PROJECT_ID="dlaojinagezrlbwyritd"
SUPABASE_URL="https://dlaojinagezrlbwyritd.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<supabase anon/publishable key>"

VITE_SUPABASE_PROJECT_ID="dlaojinagezrlbwyritd"
VITE_SUPABASE_URL="https://dlaojinagezrlbwyritd.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase anon/publishable key>"
